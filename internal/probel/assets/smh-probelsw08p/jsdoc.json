{
    "tags": {
        "allowUnknownTags": [
            "optional"
        ]
    },
    "source": {
        "include": [
            "./src"
        ],
        "includePattern": ".ts$",
        "excludePattern": "(node_modules/|docs)"
    },
    "plugins": [
        "node_modules/better-docs/typescript"
    ],
    "opts": {
        "encoding": "utf8",
        "destination": "./docs/",
        "readme": "readme.md",
        "recurse": true,
        "verbose": true,
        "tutorials": "./docs"
    }
}
# Binaries — ignore build output, but allow vendor tools under assets/
bin/
dist/
*.exe
*.exe~
*.dll
*.so
*.dylib
!assets/**/*.exe
!assets/**/*.dll
!assets/**/*.so
!assets/**/*.dylib

# Go build cache
*.test
*.out
*.prof
coverage.html

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Secrets — never commit
.secrets/
*.pem
*.key
.env
.env.*

# Temp
/tmp/

# Ember+ reference material (user's TypeScript lib with nested git repos)
assets/smh/

# Local capture files produced by --capture
*.jsonl
!tests/fixtures/**/*.jsonl

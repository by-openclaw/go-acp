# Binaries — ignore build output, but allow vendor tools under per-protocol
# assets (internal/<proto>/assets/).
bin/
dist/
*.exe
*.exe~
*.dll
*.so
*.dylib
!internal/**/assets/**/*.exe
!internal/**/assets/**/*.dll
!internal/**/assets/**/*.so
!internal/**/assets/**/*.dylib

# Go build cache
*.test
*.out
*.prof
coverage.html

# IDE
.idea/
.vscode/
.claude/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Secrets — never commit
.secrets/
*.pem
*.key
.env
.env.*

# Temp
/tmp/

# Ember+ reference material (user's TypeScript lib with nested git repos)
internal/emberplus/assets/smh/

# Local capture files produced by --capture
*.jsonl
!tests/fixtures/**/*.jsonl

# Raw per-device captures (walk/watch/frames). These can reach 50-100+
# MB each and would blow through the GitHub free-plan LFS quota (10 GB)
# or exceed the 100 MB per-file blob limit. Keep them local only.
# Drop new VM / device capture dumps under tests/fixtures/<proto>/vm_*/,
# device_*/, or raw/ so this rule catches them. Hand-trimmed golden
# fixtures (<100 KB) can still be committed at tests/fixtures/<proto>/
# root or any other subdirectory that doesn't match the patterns below.
tests/fixtures/**/vm_*/
tests/fixtures/**/device_*/
tests/fixtures/**/raw/

# The bin/devices/ folder is where the CLI writes --capture output and
# the local tree cache during development. Never commit it.
bin/devices/

# Debug/validation scratch — root-level assets/ is a scratch dir (real
# spec assets live under internal/<proto>/assets/). captures/ keeps
# hand-curated _final reports committed; newer per-run debug dumps
# (pcapng, per-run csv/md, ember59*/, vsm_trace/, salvo_*.pcapng, etc.)
# stay local.
/assets/
captures/*.pcapng
captures/*.py
captures/*.txt
captures/commie_salvo/
captures/ember59*/
captures/vsm_trace/
captures/w6b1_provider_metrics.csv
captures/w6b1_provider_metrics.md
